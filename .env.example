ARIA_QDRANT_API_KEY=replace-with-a-long-random-key
SEARXNG_SECRET=replace-with-a-long-random-key

# Optional: publish ARIA on a different local port
ARIA_HTTP_PORT=8800
ARIA_PUBLIC_URL=http://localhost:8800

# Optional: force runtime LLM / embedding settings from the container environment.
# Leave these empty when you manage providers and profiles inside ARIA.
ARIA_LLM_API_BASE=
ARIA_LLM_MODEL=
ARIA_EMBEDDINGS_API_BASE=
ARIA_EMBEDDINGS_MODEL=
