#!/usr/bin/env bash
# ARIA runtime secrets
# Copy to config/secrets.env and fill real values where needed.
# This file stays out of Git; only this example belongs in the repo.

# Base secret for encrypted Secure Store.
export ARIA_MASTER_KEY=""

# Optional runtime signing secrets.
# If left empty, ARIA creates persistent values in config/secrets.env on first start.
export ARIA_AUTH_SIGNING_SECRET=""
export ARIA_FORGET_SIGNING_SECRET=""
